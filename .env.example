# ==========================
# Model
# ==========================
MODEL_DIR=/models/Qwen3-4B-Instruct-AWQ-4bit
MODEL_NAME=qwen3-4b

# ==========================
# Service
# ==========================
LLM_HOST=0.0.0.0
LLM_PORT=8000
LLM_API_KEY=[CHANGE_API_KEY]

# ==========================
# Inference
# ==========================
MAX_MODEL_LEN=8192
GPU_MEMORY_UTILIZATION=0.85
TENSOR_PARALLEL_SIZE=1

# ==========================
# Model Runtime
# ==========================
QUANTIZATION=awq
DTYPE=auto